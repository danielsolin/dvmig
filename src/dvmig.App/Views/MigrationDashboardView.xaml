<UserControl x:Class="dvmig.App.Views.MigrationDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Status Cards -->
        <UniformGrid Columns="3" Margin="8">
            <materialDesign:Card Margin="8" Padding="16" Background="#E8F5E9">
                <StackPanel>
                    <TextBlock Text="Success" HorizontalAlignment="Center" 
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}" Foreground="#2E7D32" />
                    <TextBlock Text="{Binding Progress.SuccessCount}" 
                               HorizontalAlignment="Center" FontSize="32" FontWeight="Bold" Foreground="#2E7D32" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="8" Padding="16" Background="#FFEBEE">
                <StackPanel>
                    <TextBlock Text="Failures" HorizontalAlignment="Center" 
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}" Foreground="#C62828" />
                    <TextBlock Text="{Binding Progress.FailureCount}" 
                               HorizontalAlignment="Center" FontSize="32" FontWeight="Bold" Foreground="#C62828" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="Progress" HorizontalAlignment="Center" 
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}" />
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 Value="{Binding Progress.ProgressPercentage}" 
                                 Width="40" Height="40" Margin="8" />
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <!-- Log View -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Migration Log" Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                       Margin="0,0,0,16" />

            <materialDesign:Card Grid.Row="1" VerticalAlignment="Stretch">
                <ListBox ItemsSource="{Binding Logs}" 
                         FontFamily="Consolas" FontSize="12" />
            </materialDesign:Card>

            <Button Grid.Row="2" Command="{Binding StartMigrationCommand}"
                    Content="RUN MIGRATION" Margin="0,16,0,0"
                    HorizontalAlignment="Center" Width="200" />
        </Grid>
    </Grid>
</UserControl>
