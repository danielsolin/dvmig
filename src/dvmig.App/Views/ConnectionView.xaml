<UserControl x:Class="dvmig.App.Views.ConnectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:dvmig.App.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:dvmig.App.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <UniformGrid Columns="2">
            <!-- Source Card -->
            <materialDesign:Card Margin="16" Padding="16" 
                                 UniformCornerRadius="8">
                <StackPanel>
                    <TextBlock Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                               Text="Source Environment" Margin="0,0,0,16" />
                    <materialDesign:PackIcon Kind="DatabaseExport" 
                                           HorizontalAlignment="Center" 
                                           Width="48" Height="48" 
                                           Margin="0,0,0,16" />
                    
                    <TextBox Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             materialDesign:HintAssist.Hint="Connection String"
                             Text="{Binding SourceConnectionString, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16" />

                    <TextBlock Text="{Binding SourceStatus}" 
                               HorizontalAlignment="Center" Margin="0,0,0,16" />

                    <Button Command="{Binding TestSourceConnectionCommand}"
                            Content="TEST CONNECTION" 
                            Style="{StaticResource MaterialDesignFlatMidPrimaryButton}" />
                </StackPanel>
            </materialDesign:Card>

            <!-- Target Card -->
            <materialDesign:Card Margin="16" Padding="16" 
                                 UniformCornerRadius="8">
                <StackPanel>
                    <TextBlock Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                               Text="Target Dataverse" Margin="0,0,0,16" />
                    <materialDesign:PackIcon Kind="DatabaseImport" 
                                           HorizontalAlignment="Center" 
                                           Width="48" Height="48" 
                                           Margin="0,0,0,16" />
                    
                    <TextBox Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             materialDesign:HintAssist.Hint="Connection String"
                             Text="{Binding TargetConnectionString, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16" />

                    <TextBlock Text="{Binding TargetStatus}" 
                               HorizontalAlignment="Center" Margin="0,0,0,16" />

                    <Button Command="{Binding TestTargetConnectionCommand}"
                            Content="TEST CONNECTION" 
                            Style="{StaticResource MaterialDesignFlatMidPrimaryButton}" />
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <!-- Bottom Action Bar -->
        <Button Grid.Row="1" HorizontalAlignment="Right" Margin="16"
                Command="{Binding ProceedToSelectionCommand}"
                IsEnabled="{Binding IsTargetConnected}"
                Content="PROCEED TO SELECTION" />
    </Grid>
</UserControl>
