<UserControl x:Class="dvmig.App.Views.ConnectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <UniformGrid Columns="2">
            <!-- Source Panel -->
            <Border Margin="10" Padding="20" Background="White" 
                    BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="Source Environment" FontSize="18" FontWeight="Bold" 
                               Margin="0,0,0,20" Foreground="#3F51B5" />
                    
                    <TextBlock Text="Connection String:" Margin="0,0,0,5" />
                    <TextBox Text="{Binding SourceConnectionString, UpdateSourceTrigger=PropertyChanged}" 
                             Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,20" />

                    <TextBlock Text="{Binding SourceStatus}" HorizontalAlignment="Center" 
                               FontWeight="SemiBold" Margin="0,0,0,20" />

                    <Button Command="{Binding TestSourceConnectionCommand}" 
                            Content="TEST CONNECTION" Padding="10,5" 
                            Background="#3F51B5" Foreground="White" BorderThickness="0" />
                </StackPanel>
            </Border>

            <!-- Target Panel -->
            <Border Margin="10" Padding="20" Background="White" 
                    BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="Target Dataverse" FontSize="18" FontWeight="Bold" 
                               Margin="0,0,0,20" Foreground="#009688" />
                    
                    <TextBlock Text="Connection String:" Margin="0,0,0,5" />
                    <TextBox Text="{Binding TargetConnectionString, UpdateSourceTrigger=PropertyChanged}" 
                             Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,20" />

                    <TextBlock Text="{Binding TargetStatus}" HorizontalAlignment="Center" 
                               FontWeight="SemiBold" Margin="0,0,0,20" />

                    <Button Command="{Binding TestTargetConnectionCommand}" 
                            Content="TEST CONNECTION" Padding="10,5" 
                            Background="#009688" Foreground="White" BorderThickness="0" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Navigation and Settings -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <CheckBox Content="Remember Connections (Encrypted)" 
                      IsChecked="{Binding RememberConnections}" 
                      VerticalAlignment="Center" Margin="0,0,20,0" />
            
            <Button Command="{Binding ProceedToSelectionCommand}" 
                    IsEnabled="{Binding IsTargetConnected}"
                    Content="PROCEED TO SELECTION →" 
                    Padding="20,10" Background="#3F51B5" Foreground="White" 
                    BorderThickness="0" />
        </StackPanel>
    </Grid>
</UserControl>
